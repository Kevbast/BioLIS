@model List<BioLab.Models.LabTest>

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Catálogo de Exámenes";
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2>
            <i class="fas fa-flask text-success"></i> Catálogo de Exámenes de Laboratorio
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo Examen
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center catalog-empty py-4">
            <i class="fas fa-info-circle"></i> 
            No hay exámenes registrados. 
            <a asp-action="Create" class="alert-link">Registrar el primero</a>
        </div>
    }
    else
    {
        <div class="card catalog-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover catalog-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre del Examen</th>
                                <th>Unidades</th>
                                <th>Tipo de Muestra</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var test in Model)
                            {
                                <tr>
                                    <td><strong>@test.TestID</strong></td>
                                    <td>
                                        <i class="fas fa-vial text-primary"></i>
                                        <strong>@test.TestName</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(test.Units))
                                        {
                                            <span class="badge bg-info">@test.Units</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin unidad</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge lab-tube-badge" style="background-color: @GetColorBadge(test.SampleType.ContainerColor); color: @GetTubeTextColor(test.SampleType.ContainerColor)">
                                            <i class="fas fa-vial"></i>
                                            @test.SampleType.SampleName
                                            @if (!string.IsNullOrEmpty(test.SampleType.ContainerColor))
                                            {
                                                <span class="lab-tube-color">(@test.SampleType.ContainerColor)</span>
                                            }
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Update" asp-route-testId="@test.TestID"
                                               class="btn btn-sm btn-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-testId="@test.TestID"
                                               class="btn btn-sm btn-danger js-delete-labtest"
                                               data-test-name="@test.TestName"
                                               title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                <div class="row">
                    <div class="col-md-6">
                        <i class="fas fa-flask"></i> 
                        Total de exámenes: <strong>@Model.Count</strong>
                    </div>
                    <div class="col-md-6 text-end">
                        @{
                            var groupedBySample = Model.GroupBy(t => t.SampleType.SampleName);
                        }
                        <i class="fas fa-vial"></i> 
                        Tipos de muestra utilizados: <strong>@groupedBySample.Count()</strong>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-labtest').forEach(function (button) {
                button.addEventListener('click', async function (event) {
                    event.preventDefault();

                    const response = await fetch(button.getAttribute('href'));
                    if (!response.ok) {
                        return;
                    }

                    const html = await response.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    const deleteForm = doc.querySelector('form[action*="/LabTests/Delete"]');
                    if (!deleteForm) {
                        return;
                    }

                    const result = await Swal.fire({
                        icon: 'warning',
                        title: 'Confirmar eliminación',
                        html: doc.querySelector('.catalog-delete-summary')?.outerHTML || `<div class="text-start"><p class="mb-0"><strong>Examen:</strong> ${button.dataset.testName || 'Seleccionado'}</p></div>`,
                        showCancelButton: true,
                        confirmButtonText: 'Sí, eliminar',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#e74a3b',
                        cancelButtonColor: '#6c757d'
                    });

                    if (!result.isConfirmed) {
                        return;
                    }

                    const postForm = document.createElement('form');
                    postForm.method = 'post';
                    postForm.action = deleteForm.getAttribute('action') || '/LabTests/Delete';

                    const antiForgery = deleteForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    if (antiForgery) {
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '__RequestVerificationToken';
                        tokenInput.value = antiForgery;
                        postForm.appendChild(tokenInput);
                    }

                    const testId = deleteForm.querySelector('input[name="TestID"], input[name="testId"]')?.value || '';
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'testId';
                    idInput.value = testId;
                    postForm.appendChild(idInput);

                    document.body.appendChild(postForm);
                    postForm.submit();
                });
            });
        })();
    </script>
}

@functions {
    string GetColorBadge(string containerColor)
    {
        return containerColor?.ToLower() switch
        {
            "rojo" => "#dc3545",
            "lila" or "morado" => "#6f42c1",
            "amarillo" => "#ffc107",
            "verde" => "#28a745",
            "azul" => "#0d6efd",
            "celeste" => "#0dcaf0",
            "gris" => "#6c757d",
            "negro" => "#212529",
            "blanco" => "#f8f9fa", // Blanco (necesitará texto oscuro)
            "transparente" => "#e9ecef", // Un gris muy clarito simulando transparencia
            _ => "#17a2b8"
        };
    }

    string GetTubeTextColor(string? containerColor)
    {
        return containerColor?.ToLower() switch
        {
            "blanco" or "amarillo" or "transparente" => "#212529",
            _ => "#ffffff"
        };
    }
}
