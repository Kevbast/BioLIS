@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    var role = User.FindFirstValue(ClaimTypes.Role);
    var username = User.FindFirstValue(ClaimTypes.Name);
}

<link rel="stylesheet" href="~/css/home-dashboard.css" asp-append-version="true" />

<div class="container-fluid mt-4 dashboard-home">
    <!-- Encabezado de bienvenida -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3 dashboard-title">
                <i class="bi bi-speedometer2 text-primary"></i> Dashboard BioLIS
            </h2>
            <p class="dashboard-subtitle">
                Bienvenido, <strong>@username</strong>
                <span class="badge bg-primary">@role</span>
            </p>
        </div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusLabels = @Html.Raw((string?)ViewData["ChartStatusLabels"] ?? "[]");
        const statusValues = @Html.Raw((string?)ViewData["ChartStatusValues"] ?? "[]");
        const dayLabels = @Html.Raw((string?)ViewData["ChartDayLabels"] ?? "[]");
        const dayValues = @Html.Raw((string?)ViewData["ChartDayValues"] ?? "[]");

        const statusCtx = document.getElementById('ordersByStatusChart');
        if (statusCtx) {
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusValues,
                        borderWidth: 1,
                        backgroundColor: ['#6c757d', '#f6c23e', '#36b9cc', '#1cc88a', '#4e73df']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }

        const daysCtx = document.getElementById('ordersLast7DaysChart');
        if (daysCtx) {
            new Chart(daysCtx, {
                type: 'bar',
                data: {
                    labels: dayLabels,
                    datasets: [{
                        label: 'Órdenes',
                        data: dayValues,
                        borderRadius: 6,
                        backgroundColor: '#4e73df'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }
    </script>
}
    </div>

    <!-- Resumen + Gráficos -->
    <div class="row mb-4 g-3 dashboard-overview">
        <div class="col-xl-7 stats-column">
            <div class="row g-3">
                <div class="col-12">
                    <div class="card border-left-primary shadow h-100 py-2 stat-card">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        @if (role == "Doctor")
                                        {
                                            <text>Mis Órdenes Hoy</text>
                                        }
                                        else
                                        {
                                            <text>Órdenes Hoy</text>
                                        }
                                    </div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">
                                        @(role == "Doctor" ? ViewBag.MyTodayOrders ?? ViewBag.TodayOrders : ViewBag.TodayOrders)
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-calendar fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-left-success shadow h-100 py-2 stat-card">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Pacientes</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalPatients</div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-users fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-left-info shadow h-100 py-2 stat-card">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Total Médicos</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalDoctors</div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-user-md fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-left-warning shadow h-100 py-2 stat-card">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Total Exámenes</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalTests</div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-flask fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-5 charts-column d-flex flex-column">
            <div class="card shadow-sm chart-card mb-3">
                <div class="card-header"><strong>Órdenes por estado</strong></div>
                <div class="card-body chart-canvas-wrap"><canvas id="ordersByStatusChart"></canvas></div>
            </div>
            <div class="card shadow-sm chart-card">
                <div class="card-header"><strong>Órdenes últimos 7 días</strong></div>
                <div class="card-body chart-canvas-wrap"><canvas id="ordersLast7DaysChart"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Accesos rápidos -->
    <div class="row mb-4">
        <div class="col-12">
            <h4 class="mb-3">Accesos Rápidos</h4>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card text-center h-100 shadow-sm quick-card">
                <div class="card-body">
                    <i class="bi bi-person-plus fa-3x text-primary mb-3 quick-icon"></i>
                    <h5 class="card-title">Registrar Paciente</h5>
                    <a asp-controller="Patients" asp-action="Create" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle"></i> Nuevo
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card text-center h-100 shadow-sm quick-card">
                <div class="card-body">
                    <i class="bi bi-file-earmark-medical fa-3x text-success mb-3 quick-icon"></i>
                    <h5 class="card-title">Nueva Orden</h5>
                    <a asp-controller="Orders" asp-action="Create" class="btn btn-success btn-sm">
                        <i class="bi bi-plus-circle"></i> Crear
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card text-center h-100 shadow-sm quick-card">
                <div class="card-body">
                    <i class="bi bi-file-earmark-text fa-3x text-info mb-3 quick-icon"></i>
                    <h5 class="card-title">Ver Órdenes</h5>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-info btn-sm">
                        <i class="bi bi-list-ul"></i> Listar
                    </a>
                </div>
            </div>
        </div>

        @if (role == "Admin")
        {
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="card text-center h-100 shadow-sm quick-card">
                    <div class="card-body">
                        <i class="bi bi-gear fa-3x text-warning mb-3 quick-icon"></i>
                        <h5 class="card-title">Administración</h5>
                        <a asp-controller="Users" asp-action="Index" class="btn btn-warning btn-sm">
                            <i class="bi bi-people"></i> Usuarios
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Órdenes recientes -->
    @if (ViewBag.RecentOrders != null && ((List<BioLab.Models.Order>)ViewBag.RecentOrders).Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card shadow mb-4 recent-orders-card">
                    <div class="card-header py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary">
                            @if (role == "Doctor")
                            {
                                <text>Mis Órdenes Recientes</text>
                            }
                            else
                            {
                                <text>Órdenes Recientes</text>
                            }
                        </h6>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-primary">
                            Ver todas <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover orders-table">
                                <thead>
                                    <tr>
                                        <th>Número Orden</th>
                                        <th>Paciente</th>
                                        <th>Médico</th>
                                        <th>Fecha</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in (List<BioLab.Models.Order>)ViewBag.RecentOrders)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@order.OrderNumber</strong>
                                            </td>
                                            <td>@order.Patient?.FullName</td>
                                            <td>@order.Doctor?.FullName</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                @if (order.Status == "Aprobada")
                                                {
                                                    <span class="badge bg-success"><i class="fas fa-check-circle"></i> Aprobada</span>
                                                }
                                                else if (order.Status == "Completada")
                                                {
                                                    <span class="badge bg-info text-dark"><i class="fas fa-check-double"></i> Completada</span>
                                                }
                                                else if (order.Status == "EnProceso")
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="fas fa-spinner"></i> En Proceso</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary"><i class="fas fa-clock"></i> Pendiente</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="Orders" asp-action="Details" asp-route-orderId="@order.OrderID"
                                                   class="btn btn-sm btn-info">
                                                    <i class="bi bi-eye"></i> Ver
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
