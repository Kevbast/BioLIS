@{
    ViewData["Title"] = "Crear Tipo de Muestra";
}

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2><i class="fas fa-vial text-success"></i> Registrar Nuevo Tipo de Muestra</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card catalog-card">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Registrar Nuevo Tipo de Muestra
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Create" method="post" class="catalog-form" id="sampleTypeCreateForm">
                        @Html.AntiForgeryToken()

                        <!-- Nombre del Tipo de Muestra -->
                        <div class="mb-3">
                            <label for="sampleName" class="form-label">
                                <i class="fas fa-vial"></i> Nombre del Tipo de Muestra *
                            </label>
                            <input type="text" class="form-control" id="sampleName" name="sampleName" 
                                   placeholder="Ej: Suero, Sangre Total, Plasma, Orina" 
                                   required maxlength="50" />
                            <small class="form-text text-muted">
                                Tipo de muestra biológica que se recolectará
                            </small>
                        </div>

                        <!-- Color del Tubo -->
                        <div class="mb-3">
                            <label for="containerColor" class="form-label">
                                <i class="fas fa-palette"></i> Color del Tubo/Recipiente
                            </label>
                            <select class="form-select" id="containerColor" name="containerColor">
                                <option value="">-- Sin color específico --</option>
                                <option value="Rojo">?? Rojo</option>
                                <option value="Lila">?? Lila/Morado (EDTA)</option>
                                <option value="Amarillo">?? Amarillo (Gel separador)</option>
                                <option value="Verde">?? Verde (Heparina)</option>
                                <option value="Azul">?? Azul (Citrato)</option>
                                <option value="Gris">? Gris (Fluoruro)</option>
                                <option value="Negro">? Negro</option>
                            </select>
                            <small class="form-text text-muted">
                                El color del tubo indica el aditivo/anticoagulante que contiene
                            </small>
                        </div>

                        <!-- Botones -->
                        <div class="catalog-actions mt-4 d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-success" id="btnCreateSampleType">
                                <i class="fas fa-save"></i> Crear Tipo de Muestra
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Información adicional -->
            <div class="alert alert-info mt-3">
                <i class="fas fa-info-circle"></i> 
                <strong>Guía de Tubos Comunes:</strong>
                <ul class="mb-0 mt-2">
                    <li><strong>Tubo Rojo</strong> - Sin anticoagulante, para obtener suero (química clínica)</li>
                    <li><strong>Tubo Lila/Morado (EDTA)</strong> - Para hematología completa (CBC)</li>
                    <li><strong>Tubo Amarillo</strong> - Gel separador, para química clínica</li>
                    <li><strong>Tubo Verde (Heparina)</strong> - Para determinaciones urgentes de química</li>
                    <li><strong>Tubo Azul (Citrato)</strong> - Para coagulación (PT, PTT)</li>
                    <li><strong>Tubo Gris (Fluoruro)</strong> - Para glucosa (inhibe glucólisis)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('sampleTypeCreateForm');
            const submitButton = document.getElementById('btnCreateSampleType');

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function () {
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';
            });
        })();
    </script>
}
