@model BioLab.Models.SampleType

@{
    ViewData["Title"] = "Editar Tipo de Muestra";
}

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2><i class="fas fa-edit text-warning"></i> Editar Tipo de Muestra</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card catalog-card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Editar Tipo de Muestra: @Model.SampleName
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Update" method="post" class="catalog-form" id="sampleTypeUpdateForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="SampleID" />

                        <!-- Nombre del Tipo de Muestra -->
                        <div class="mb-3">
                            <label asp-for="SampleName" class="form-label">
                                <i class="fas fa-vial"></i> Nombre del Tipo de Muestra *
                            </label>
                            <input asp-for="SampleName" class="form-control" 
                                   placeholder="Ej: Suero, Sangre Total" 
                                   required maxlength="50" />
                        </div>

                        <!-- Color del Tubo -->
                        <div class="mb-3">
                            <label asp-for="ContainerColor" class="form-label">
                                <i class="fas fa-palette"></i> Color del Tubo/Recipiente
                            </label>
                            <select asp-for="ContainerColor" class="form-select">
                                <option value="">-- Sin color específico --</option>
                                <option value="Rojo">?? Rojo</option>
                                <option value="Lila">?? Lila/Morado (EDTA)</option>
                                <option value="Amarillo">?? Amarillo (Gel separador)</option>
                                <option value="Verde">?? Verde (Heparina)</option>
                                <option value="Azul">?? Azul (Citrato)</option>
                                <option value="Celeste">🟦 Celeste (Coagulación especializada/plasma)</option>
                                <option value="Gris">? Gris (Fluoruro)</option>
                                <option value="Negro">? Negro</option>
                                <option value="amarillo">🟡 Bote Amarillo/Translúcido (Orina)</option>
                                <option value="blanco">⚪ Bote Blanco/Opaco (Heces)</option>
                                <option value="transparente">🫙 Transparente/Hisopo (Saliva/Exudados)</option>
                            </select>
                        </div>

                        <!-- Botones -->
                        <div class="catalog-actions mt-4 d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning" id="btnUpdateSampleType">
                                <i class="fas fa-save"></i> Actualizar Tipo de Muestra
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-3">
                <i class="fas fa-exclamation-triangle"></i> 
                <strong>Advertencia:</strong>
                <p class="mb-0 mt-2">
                    Si cambia el nombre o color de este tipo de muestra, 
                    afectará a todos los exámenes que lo utilizan.
                </p>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('sampleTypeUpdateForm');
            const submitButton = document.getElementById('btnUpdateSampleType');

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function () {
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Actualizando...';
            });
        })();
    </script>
}
</div>
