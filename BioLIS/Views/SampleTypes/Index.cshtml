@model List<BioLab.Models.SampleType>

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Tipos de Muestra";
    var usageStats = ViewData["UsageStats"] as dynamic;
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2>
            <i class="fas fa-vial text-info"></i> Tipos de Muestra y Tubos
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo Tipo de Muestra
        </a>
    </div>

    <!-- Información sobre tipos de muestra -->
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> 
        <strong>żQué son los Tipos de Muestra?</strong>
        <p class="mb-0 mt-2">
            Los tipos de muestra definen qué tubos o recipientes se deben usar para cada examen de laboratorio.
            Cada tubo tiene un color específico y contiene aditivos necesarios para preservar la muestra.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center catalog-empty py-4">
            <i class="fas fa-info-circle"></i> 
            No hay tipos de muestra registrados. 
            <a asp-action="Create" class="alert-link">Registrar el primero</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in usageStats)
            {
                var sampleType = item.SampleType as SampleType;
                var testCount = (int)item.TestCount;

                <div class="col-md-4 mb-4">
                    <div class="card h-100 catalog-list-card">
                        <div class="card-header text-white" style="background-color: @GetColorBadge(sampleType.ContainerColor)">
                            <h5 class="mb-0">
                                <i class="fas fa-test-tube"></i> @sampleType.SampleName
                            </h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">ID:</dt>
                                <dd class="col-sm-7">@sampleType.SampleID</dd>

                                <dt class="col-sm-5">Color del Tubo:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge" style="background-color: @GetColorBadge(sampleType.ContainerColor); color: white;">
                                        @sampleType.ContainerColor
                                    </span>
                                </dd>

                                <dt class="col-sm-5">Exámenes:</dt>
                                <dd class="col-sm-7">
                                    @if (testCount > 0)
                                    {
                                        <span class="badge bg-primary">@testCount examen(es)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Sin exámenes</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Update" asp-route-sampleId="@sampleType.SampleID"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-sampleId="@sampleType.SampleID"
                                   class="btn btn-sm btn-danger js-delete-sample"
                                   data-sample-name="@sampleType.SampleName"
                                   title="Eliminar">
                                    <i class="fas fa-trash"></i> Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card catalog-card mt-4">
            <div class="card-body">
                <h5><i class="fas fa-chart-bar"></i> Estadísticas</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Total de Tipos de Muestra:</strong> @Model.Count</p>
                    </div>
                    <div class="col-md-6">
                        @{
                            int totalExams = 0;
                            foreach (var item in usageStats)
                            {
                                totalExams += (int)item.TestCount;
                            }
                        }
                        <p><strong>Total de Exámenes Configurados:</strong> @totalExams</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-sample').forEach(function (button) {
                button.addEventListener('click', async function (event) {
                    event.preventDefault();

                    const response = await fetch(button.getAttribute('href'));
                    if (!response.ok) {
                        return;
                    }

                    const html = await response.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    const deleteForm = doc.querySelector('form[action*="/SampleTypes/Delete"]');
                    if (!deleteForm) {
                        return;
                    }

                    const result = await Swal.fire({
                        icon: 'warning',
                        title: 'Confirmar eliminación',
                        html: doc.querySelector('.catalog-delete-summary')?.outerHTML || `<div class="text-start"><p class="mb-0"><strong>Tipo:</strong> ${button.dataset.sampleName || 'Seleccionado'}</p></div>`,
                        showCancelButton: true,
                        confirmButtonText: 'Sí, eliminar',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#e74a3b',
                        cancelButtonColor: '#6c757d'
                    });

                    if (!result.isConfirmed) {
                        return;
                    }

                    const postForm = document.createElement('form');
                    postForm.method = 'post';
                    postForm.action = deleteForm.getAttribute('action') || '/SampleTypes/Delete';

                    const antiForgery = deleteForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    if (antiForgery) {
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '__RequestVerificationToken';
                        tokenInput.value = antiForgery;
                        postForm.appendChild(tokenInput);
                    }

                    const sampleId = deleteForm.querySelector('input[name="SampleID"], input[name="sampleId"]')?.value || '';
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'sampleId';
                    idInput.value = sampleId;
                    postForm.appendChild(idInput);

                    document.body.appendChild(postForm);
                    postForm.submit();
                });
            });
        })();
    </script>
}

@functions {
    string GetColorBadge(string containerColor)
    {
        return containerColor?.ToLower() switch
        {
            "rojo" => "#dc3545",
            "lila" or "morado" => "#6f42c1",
            "amarillo" => "#ffc107",
            "verde" => "#28a745",
            "azul" => "#007bff",
            "gris" => "#6c757d",
            "negro" => "#212529",
            _ => "#17a2b8"
        };
    }
}
