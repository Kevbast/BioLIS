@model BioLab.Models.ReferenceRange

@{
    ViewData["Title"] = "Eliminar Rango de Referencia";
}

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

<div class="container mt-4 catalog-page">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card catalog-card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Confirmar Eliminación de Rango
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger catalog-delete-summary">
                        <i class="fas fa-skull-crossbones"></i>
                        <strong>ˇADVERTENCIA!</strong> 
                        Esta acción eliminará permanentemente este rango de referencia.
                        <p class="mb-0 mt-2">
                            Los resultados existentes ya validados no cambiarán, pero las nuevas validaciones 
                            no usarán este rango.
                        </p>
                    </div>

                    <h5 class="mb-3"><i class="fas fa-chart-line"></i> Datos del Rango</h5>

                    <dl class="row">
                        <dt class="col-sm-4"><i class="fas fa-hashtag"></i> ID:</dt>
                        <dd class="col-sm-8">@Model.RangeID</dd>

                        <dt class="col-sm-4"><i class="fas fa-flask"></i> Examen:</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.LabTest.TestName</strong>
                            @if (!string.IsNullOrEmpty(Model.LabTest.Units))
                            {
                                <span class="badge bg-info">@Model.LabTest.Units</span>
                            }
                        </dd>

                        <dt class="col-sm-4"><i class="fas fa-venus-mars"></i> Género:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Gender == "M")
                            {
                                <span class="badge bg-primary">
                                    <i class="fas fa-mars"></i> Masculino
                                </span>
                            }
                            else if (Model.Gender == "F")
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-venus"></i> Femenino
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="fas fa-venus-mars"></i> Ambos
                                </span>
                            }
                        </dd>

                        <dt class="col-sm-4"><i class="fas fa-birthday-cake"></i> Rango de Edad:</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.MinAgeYear - @Model.MaxAgeYear ańos</strong>
                        </dd>

                        <dt class="col-sm-4"><i class="fas fa-chart-bar"></i> Valores Normales:</dt>
                        <dd class="col-sm-8">
                            <span class="text-danger">@Model.MinVal</span> 
                            - 
                            <span class="text-success">@Model.MaxVal</span>
                            @if (!string.IsNullOrEmpty(Model.LabTest.Units))
                            {
                                <span>@Model.LabTest.Units</span>
                            }
                        </dd>

                        <dt class="col-sm-4"><i class="fas fa-info-circle"></i> Descripción:</dt>
                        <dd class="col-sm-8">
                            Rango para 
                            @if (Model.Gender == "M") { <text>hombres</text> }
                            else if (Model.Gender == "F") { <text>mujeres</text> }
                            else { <text>todos</text> }
                            de @Model.MinAgeYear a @Model.MaxAgeYear ańos
                        </dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="RangeID" />
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Sí, Eliminar Rango
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <i class="fas fa-info-circle"></i> 
                <strong>Nota:</strong> 
                La eliminación de este rango no afecta resultados ya guardados, 
                solo las validaciones futuras.
            </div>
        </div>
    </div>
</div>
