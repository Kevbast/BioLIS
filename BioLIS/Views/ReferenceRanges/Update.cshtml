@model BioLab.Models.ReferenceRange

@{
    ViewData["Title"] = "Editar Rango de Referencia";
    var labTests = ViewData["LabTests"] as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2><i class="fas fa-edit text-warning"></i> Editar Rango de Referencia</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card catalog-card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Editar Rango de Referencia
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Update" method="post" class="catalog-form" id="rangeUpdateForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="RangeID" />

                        <div class="row">
                            <!-- Examen -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="TestID" class="form-label">
                                    <i class="fas fa-flask"></i> Examen *
                                </label>
                                <select asp-for="TestID" class="form-select" required>
                                    <option value="">-- Seleccione el examen --</option>
                                    @foreach (var test in labTests)
                                    {
                                        <option value="@test.Value" selected="@test.Selected">@test.Text</option>
                                    }
                                </select>
                            </div>

                            <!-- Género -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label">
                                    <i class="fas fa-venus-mars"></i> Género *
                                </label>
                                <select asp-for="Gender" class="form-select" required>
                                    <option value="">-- Seleccione el género --</option>
                                    <option value="M">?? Masculino</option>
                                    <option value="F">?? Femenino</option>
                                    <option value="A">? Ambos (A)</option>
                                </select>
                            </div>
                        </div>

                        <!-- Rango de Edad -->
                        <div class="card mb-3 catalog-card">
                            <div class="card-header bg-info text-white">
                                <h6 class="mb-0"><i class="fas fa-birthday-cake"></i> Rango de Edad</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label asp-for="MinAgeYear" class="form-label">
                                            Edad Mínima (ańos) *
                                        </label>
                                        <input asp-for="MinAgeYear" type="number" class="form-control" 
                                               min="0" max="120" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="MaxAgeYear" class="form-label">
                                            Edad Máxima (ańos) *
                                        </label>
                                        <input asp-for="MaxAgeYear" type="number" class="form-control" 
                                               min="0" max="120" required />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Rango de Valores -->
                        <div class="card mb-3 catalog-card">
                            <div class="card-header bg-warning text-dark">
                                <h6 class="mb-0"><i class="fas fa-chart-line"></i> Valores del Rango</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label asp-for="MinVal" class="form-label">
                                            <span class="text-danger">Valor Mínimo *</span>
                                        </label>
                                        <input asp-for="MinVal" type="number" step="0.01" class="form-control" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="MaxVal" class="form-label">
                                            <span class="text-success">Valor Máximo *</span>
                                        </label>
                                        <input asp-for="MaxVal" type="number" step="0.01" class="form-control" required />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="catalog-actions mt-4 d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning btn-lg" id="btnUpdateRange">
                                <i class="fas fa-save"></i> Actualizar Rango
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-3">
                <i class="fas fa-exclamation-triangle"></i> 
                <strong>Advertencia:</strong>
                <p class="mb-0 mt-2">
                    Si cambia los valores de este rango, afectará la validación de resultados existentes y futuros.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const form = document.getElementById('rangeUpdateForm');
            const submitButton = document.getElementById('btnUpdateRange');

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function (e) {
                const minAge = parseInt(document.getElementById('MinAgeYear').value || '0', 10);
                const maxAge = parseInt(document.getElementById('MaxAgeYear').value || '0', 10);
                const minVal = parseFloat(document.getElementById('MinVal').value || '0');
                const maxVal = parseFloat(document.getElementById('MaxVal').value || '0');

                if (minAge >= maxAge) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Rango de edad inválido',
                        text: 'La edad mínima debe ser menor que la edad máxima.',
                        confirmButtonColor: '#4e73df'
                    });
                    return;
                }

                if (minVal >= maxVal) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Rango de valores inválido',
                        text: 'El valor mínimo debe ser menor que el valor máximo.',
                        confirmButtonColor: '#4e73df'
                    });
                    return;
                }

                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Actualizando...';
            });
        })();
    </script>
}
