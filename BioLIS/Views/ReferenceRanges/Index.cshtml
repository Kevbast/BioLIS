@model List<BioLab.Models.ReferenceRange>

@{
    ViewData["Title"] = "Rangos de Referencia";
    var groupedRanges = ViewData["GroupedRanges"] as IEnumerable<IGrouping<string, BioLab.Models.ReferenceRange>>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-chart-line text-primary"></i> Rangos de Referencia
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo Rango
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Información -->
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> 
        <strong>żQué son los Rangos de Referencia?</strong>
        <p class="mb-0 mt-2">
            Los rangos de referencia definen los valores normales para cada examen según la edad y género del paciente.
            El sistema los usa automáticamente para validar si un resultado es Normal, Anormal o Crítico.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="fas fa-info-circle"></i> 
            No hay rangos de referencia configurados. 
            <a asp-action="Create" class="alert-link">Crear el primero</a>
        </div>
    }
    else
    {
        <!-- Agrupar por Examen -->
        @foreach (var group in groupedRanges)
        {
            var firstRange = group.First();
            
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-vial"></i> @group.Key
                        @if (!string.IsNullOrEmpty(firstRange.LabTest.Units))
                        {
                            <span class="badge bg-light text-dark">@firstRange.LabTest.Units</span>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Género</th>
                                    <th>Edad (ańos)</th>
                                    <th>Valor Mínimo</th>
                                    <th>Valor Máximo</th>
                                    <th>Rango</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var range in group.OrderBy(r => r.Gender).ThenBy(r => r.MinAgeYear))
                                {
                                    <tr>
                                        <td>
                                            @if (range.Gender == "M")
                                            {
                                                <span class="badge bg-primary">
                                                    <i class="fas fa-mars"></i> Masculino
                                                </span>
                                            }
                                            else if (range.Gender == "F")
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-venus"></i> Femenino
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-venus-mars"></i> Ambos
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <strong>@range.MinAgeYear - @range.MaxAgeYear</strong>
                                        </td>
                                        <td><span class="text-danger">@range.MinVal</span></td>
                                        <td><span class="text-success">@range.MaxVal</span></td>
                                        <td>
                                            <span class="badge bg-info">
                                                @range.MinVal - @range.MaxVal @firstRange.LabTest.Units
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Update" asp-route-rangeId="@range.RangeID"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-rangeId="@range.RangeID"
                                                   class="btn btn-sm btn-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow">
            <div class="card-body">
                <h5><i class="fas fa-chart-bar"></i> Estadísticas</h5>
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Total de Rangos:</strong> @Model.Count</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Exámenes Configurados:</strong> @groupedRanges.Count()</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Rangos por Género:</strong> @Model.Count(r => r.Gender != "A")</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
