@model List<BioLIS.Models.ReferenceRange>

<link rel="stylesheet" href="~/css/catalog-modules.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Rangos de Referencia";
    var groupedRanges = ViewData["GroupedRanges"] as IEnumerable<IGrouping<string, BioLIS.Models.ReferenceRange>>;
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 catalog-page">
    <div class="catalog-header">
        <h2>
            <i class="fas fa-chart-line text-primary"></i> Rangos de Referencia
        </h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nuevo Rango
        </a>
    </div>

    <!-- Información -->
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> 
        <strong>żQué son los Rangos de Referencia?</strong>
        <p class="mb-0 mt-2">
            Los rangos de referencia definen los valores normales para cada examen según la edad y género del paciente.
            El sistema los usa automáticamente para validar si un resultado es Normal, Anormal o Crítico.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center catalog-empty py-4">
            <i class="fas fa-info-circle"></i> 
            No hay rangos de referencia configurados. 
            <a asp-action="Create" class="alert-link">Crear el primero</a>
        </div>
    }
    else
    {
        <!-- Agrupar por Examen -->
        @foreach (var group in groupedRanges)
        {
            var firstRange = group.First();
            
            <div class="card catalog-list-card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-vial"></i> @group.Key
                        @if (!string.IsNullOrEmpty(firstRange.LabTest.Units))
                        {
                            <span class="badge bg-light text-dark">@firstRange.LabTest.Units</span>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover catalog-table">
                            <thead>
                                <tr>
                                    <th>Género</th>
                                    <th>Edad (ańos)</th>
                                    <th>Valor Mínimo</th>
                                    <th>Valor Máximo</th>
                                    <th>Rango</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var range in group.OrderBy(r => r.Gender).ThenBy(r => r.MinAgeYear))
                                {
                                    <tr>
                                        <td>
                                            @if (range.Gender == "M")
                                            {
                                                <span class="badge bg-primary">
                                                    <i class="fas fa-mars"></i> Masculino
                                                </span>
                                            }
                                            else if (range.Gender == "F")
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-venus"></i> Femenino
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-venus-mars"></i> Ambos
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <strong>@range.MinAgeYear - @range.MaxAgeYear</strong>
                                        </td>
                                        <td><span class="text-danger">@range.MinVal</span></td>
                                        <td><span class="text-success">@range.MaxVal</span></td>
                                        <td>
                                            <span class="badge bg-info">
                                                @range.MinVal - @range.MaxVal @firstRange.LabTest.Units
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Update" asp-route-rangeId="@range.RangeID"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-rangeId="@range.RangeID"
                                                   class="btn btn-sm btn-danger js-delete-range"
                                                   data-range-id="@range.RangeID"
                                                   title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div class="card catalog-card">
            <div class="card-body">
                <h5><i class="fas fa-chart-bar"></i> Estadísticas</h5>
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Total de Rangos:</strong> @Model.Count</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Exámenes Configurados:</strong> @groupedRanges.Count()</p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Rangos por Género:</strong> @Model.Count(r => r.Gender != "A")</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-range').forEach(function (button) {
                button.addEventListener('click', async function (event) {
                    event.preventDefault();

                    const response = await fetch(button.getAttribute('href'));
                    if (!response.ok) {
                        return;
                    }

                    const html = await response.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    const deleteForm = doc.querySelector('form[action*="/ReferenceRanges/Delete"]');
                    if (!deleteForm) {
                        return;
                    }

                    const result = await Swal.fire({
                        icon: 'warning',
                        title: 'Confirmar eliminación',
                        html: doc.querySelector('.catalog-delete-summary')?.outerHTML || `<div class="text-start"><p class="mb-0"><strong>Rango:</strong> ID ${button.dataset.rangeId}</p></div>`,
                        showCancelButton: true,
                        confirmButtonText: 'Sí, eliminar',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#e74a3b',
                        cancelButtonColor: '#6c757d'
                    });

                    if (!result.isConfirmed) {
                        return;
                    }

                    const postForm = document.createElement('form');
                    postForm.method = 'post';
                    postForm.action = deleteForm.getAttribute('action') || '/ReferenceRanges/Delete';

                    const antiForgery = deleteForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    if (antiForgery) {
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '__RequestVerificationToken';
                        tokenInput.value = antiForgery;
                        postForm.appendChild(tokenInput);
                    }

                    const rangeId = deleteForm.querySelector('input[name="RangeID"], input[name="rangeId"]')?.value || '';
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'rangeId';
                    idInput.value = rangeId;
                    postForm.appendChild(idInput);

                    document.body.appendChild(postForm);
                    postForm.submit();
                });
            });
        })();
    </script>
}
