@model BioLab.Models.User

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />

<div class="container mt-4 users-page">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card users-card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Confirmar Eliminación de Usuario
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger users-delete-summary">
                        <i class="fas fa-skull-crossbones"></i>
                        <strong>ˇADVERTENCIA!</strong> 
                        Esta acción eliminará permanentemente este usuario del sistema.
                        <p class="mb-0 mt-2">El usuario no podrá iniciar sesión nuevamente.</p>
                    </div>

                    <h5 class="mb-3"><i class="fas fa-user"></i> Datos del Usuario</h5>

                    <div class="row mb-3">
                        <div class="col-md-3 text-center">
                            <img src="~/images/users/@Model.PhotoFilename" 
                                 alt="@Model.Username" 
                                 class="rounded-circle border border-3 border-danger" 
                                 style="width: 100px; height: 100px; object-fit: cover;" 
                                 onerror="this.src='/images/users/default-user.png'" />
                        </div>
                        <div class="col-md-9">
                            <dl class="row">
                                <dt class="col-sm-4"><i class="fas fa-hashtag"></i> ID:</dt>
                                <dd class="col-sm-8">@Model.UserID</dd>

                                <dt class="col-sm-4"><i class="fas fa-user"></i> Usuario:</dt>
                                <dd class="col-sm-8"><strong>@Model.Username</strong></dd>

                                <dt class="col-sm-4"><i class="fas fa-envelope"></i> Email:</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.Email))
                                    {
                                        @Model.Email
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin email</span>
                                    }
                                </dd>

                                <dt class="col-sm-4"><i class="fas fa-user-tag"></i> Rol:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.Role == "Admin")
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-crown"></i> @Model.Role</span>
                                    }
                                    else if (Model.Role == "Doctor")
                                    {
                                        <span class="badge bg-primary"><i class="fas fa-user-md"></i> @Model.Role</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="fas fa-flask"></i> @Model.Role</span>
                                    }
                                </dd>

                                <dt class="col-sm-4"><i class="fas fa-stethoscope"></i> Doctor Vinculado:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.DoctorID.HasValue)
                                    {
                                        <span class="text-success">ID: @Model.DoctorID</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No aplica</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="UserID" />
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Sí, Eliminar Usuario
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.DoctorID.HasValue)
            {
                <div class="alert alert-info mt-3">
                    <i class="fas fa-info-circle"></i> 
                    <strong>Nota:</strong> 
                    Si elimina este usuario, el médico vinculado (ID: @Model.DoctorID) quedará disponible 
                    para asignarse a otro usuario en el futuro.
                </div>
            }
        </div>
    </div>
</div>
