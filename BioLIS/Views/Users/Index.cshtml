@model List<BioLab.Models.User>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    var doctorNames = ViewBag.Doctors as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-users"></i> Gestión de Usuarios
            <span class="badge bg-info">@Model.Count usuarios</span>
        </h2>
        <div>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-user-plus"></i> Crear Nuevo Usuario
            </a>
            <a asp-action="Stats" class="btn btn-info">
                <i class="fas fa-chart-bar"></i> Estadísticas
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> <strong>Éxito:</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> <strong>Error:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Foto</th>
                            <th>Usuario</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th>Médico Vinculado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td><strong>@user.UserID</strong></td>
                                <td>
                                    <img src="~/images/users/@user.PhotoFilename" 
                                         alt="@user.Username" 
                                         class="rounded-circle" 
                                         style="width: 40px; height: 40px; object-fit: cover;" 
                                         onerror="this.src='/images/users/default-user.png'" />
                                </td>
                                <td>
                                    <strong>@user.Username</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.Email))
                                    {
                                        <span><i class="fas fa-envelope text-secondary"></i> @user.Email</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin email</span>
                                    }
                                </td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-crown"></i> @user.Role</span>
                                    }
                                    else if (user.Role == "Doctor")
                                    {
                                        <span class="badge bg-primary"><i class="fas fa-user-md"></i> @user.Role</span>
                                    }
                                    else if (user.Role == "Laboratorio")
                                    {
                                        <span class="badge bg-success"><i class="fas fa-flask"></i> @user.Role</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@user.Role</span>
                                    }
                                </td>
                                <td>
                                    @if (user.DoctorID.HasValue)
                                    {
                                        @if (doctorNames.ContainsKey(user.DoctorID.Value))
                                        {
                                            <span class="text-success">
                                                <i class="fas fa-stethoscope"></i> 
                                                @doctorNames[user.DoctorID.Value]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-warning">
                                                <i class="fas fa-question-circle"></i> 
                                                ID: @user.DoctorID
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @* Solo permitir eliminar si no es el último admin *@
                                    @if (user.Role != "Admin" || Model.Count(u => u.Role == "Admin") > 1)
                                    {
                                        <a asp-action="Delete" asp-route-id="@user.UserID" 
                                           class="btn btn-sm btn-danger"
                                           title="Eliminar usuario">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary" disabled 
                                                title="No se puede eliminar el único administrador">
                                            <i class="fas fa-lock"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted">
            <div class="row">
                <div class="col-md-4">
                    <i class="fas fa-crown text-danger"></i> 
                    Admins: <strong>@Model.Count(u => u.Role == "Admin")</strong>
                </div>
                <div class="col-md-4">
                    <i class="fas fa-user-md text-primary"></i> 
                    Doctores: <strong>@Model.Count(u => u.Role == "Doctor")</strong>
                </div>
                <div class="col-md-4">
                    <i class="fas fa-flask text-success"></i> 
                    Laboratorio: <strong>@Model.Count(u => u.Role == "Laboratorio")</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-ocultar alertas después de 5 segundos
        setTimeout(function () {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
