@model List<BioLab.Models.User>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h2>
                ?? Gestión de Usuarios
                <span class="badge bg-info">@Model.Count usuarios</span>
            </h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-success">
                ? Crear Nuevo Usuario
            </a>
            <a asp-action="Stats" class="btn btn-info">
                ?? Estadísticas
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>? Éxito:</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>?? Error:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Foto</th>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Doctor Asociado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.UserID</strong></td>
                            <td>
                                <img src="~/images/users/@user.PhotoFilename" 
                                     alt="@user.Username" 
                                     class="rounded-circle" 
                                     style="width: 40px; height: 40px; object-fit: cover;" 
                                     onerror="this.src='/images/users/default-user.png'" />
                            </td>
                            <td><strong>@user.Username</strong></td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger">??? @user.Role</span>
                                }
                                else if (user.Role == "Doctor")
                                {
                                    <span class="badge bg-primary">????? @user.Role</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@user.Role</span>
                                }
                            </td>
                            <td>
                                @if (user.DoctorID.HasValue)
                                {
                                    <span class="text-success">ID: @user.DoctorID</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @if (user.Role != "Admin" || Model.Count(u => u.Role == "Admin") > 1)
                                {
                                    <a asp-action="Delete" asp-route-id="@user.UserID" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('żEstás seguro de eliminar este usuario?')">
                                        ??? Eliminar
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary" disabled>
                                        ?? Protegido
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            ?? Volver al inicio
        </a>
    </div>
</div>
