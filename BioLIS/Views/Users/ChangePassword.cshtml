@{
    ViewData["Title"] = "Cambiar Contraseńa";
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />

<div class="container users-page">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card users-card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-key"></i> Cambiar Contraseńa</h4>
                </div>
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post" class="users-form" id="changePasswordForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="currentPassword" class="form-label">Contraseńa Actual</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="currentPassword" 
                                   name="currentPassword" 
                                   required 
                                   placeholder="Ingresa tu contraseńa actual" />
                        </div>

                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Nueva Contraseńa</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="newPassword" 
                                   name="newPassword" 
                                   required 
                                   minlength="5"
                                   placeholder="Ingresa tu nueva contraseńa" />
                            <small class="text-muted">Mínimo 5 caracteres</small>
                        </div>

                        <div class="mb-4">
                            <label for="confirmPassword" class="form-label">Confirmar Nueva Contraseńa</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="confirmPassword" 
                                   name="confirmPassword" 
                                   required 
                                   minlength="5"
                                   placeholder="Confirma tu nueva contraseńa" />
                        </div>

                        <div class="users-actions d-grid gap-2">
                            <button type="submit" class="btn btn-primary" id="btnChangePassword">
                                <i class="fas fa-save"></i> Cambiar Contraseńa
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <h6><i class="fas fa-shield-alt"></i> Consejos de Seguridad:</h6>
                <ul class="mb-0">
                    <li>Usa contraseńas únicas y seguras</li>
                    <li>No compartas tu contraseńa con nadie</li>
                    <li>Cambia tu contraseńa periódicamente</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));
            const form = document.getElementById('changePasswordForm');
            const submitButton = document.getElementById('btnChangePassword');

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df'
                });
            }

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function(e) {
                const newPass = document.getElementById('newPassword').value;
                const confirmPass = document.getElementById('confirmPassword').value;

                if (newPass !== confirmPass) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Contraseńas no coinciden',
                        text: 'Verifica que la nueva contraseńa y su confirmación sean iguales.',
                        confirmButtonColor: '#4e73df'
                    });
                    return;
                }

                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Actualizando...';
            });
        })();
    </script>
}
