@model BioLIS.Models.User

@{
    ViewData["Title"] = "Cambiar Contraseþa";
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />

<div class="container users-page mt-4">
    <div class="users-header">
        <h2><i class="fas fa-user-cog text-primary"></i> Mi Perfil</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card users-card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-id-card"></i> Datos del Usuario</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <img src="~/images/users/@(Model?.PhotoFilename ?? "default-user.png")"
                             alt="Perfil"
                             class="rounded-circle border border-3 border-info"
                             style="width: 120px; height: 120px; object-fit: cover;"
                             onerror="this.src='/images/users/default-user.png'" />
                    </div>

                    <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="users-form" id="updateProfileForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="username" class="form-label">Usuario</label>
                            <input type="text" class="form-control" id="username" name="username" value="@Model?.Username" required />
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" value="@Model?.Email" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Rol</label>
                            <input type="text" class="form-control" value="@Model?.Role" readonly />
                        </div>

                        @if (Model?.DoctorID.HasValue ?? false)
                        {
                            <div class="mb-3">
                                <label class="form-label">MÕdico Vinculado</label>
                                <input type="text" class="form-control" value="@(Model?.Doctor?.FullName ?? $"ID: {Model?.DoctorID}")" readonly />
                            </div>
                        }

                        <div class="mb-4">
                            <label for="photoFile" class="form-label">Foto de Perfil</label>
                            <input type="file" class="form-control" id="photoFile" name="photoFile" accept="image/*" />
                        </div>

                        <button type="submit" class="btn btn-info w-100" id="btnUpdateProfile">
                            <i class="fas fa-save"></i> Guardar Datos del Perfil
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card users-card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-key"></i> Actualizar Contraseþa</h5>
                </div>
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post" class="users-form" id="changePasswordForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="currentPassword" class="form-label">Contraseþa Actual</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword" required placeholder="Ingresa tu contraseþa actual" />
                        </div>

                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Nueva Contraseþa</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="5" placeholder="Ingresa tu nueva contraseþa" />
                            <small class="text-muted">MÚnimo 5 caracteres</small>
                        </div>

                        <div class="mb-4">
                            <label for="confirmPassword" class="form-label">Confirmar Nueva Contraseþa</label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="5" placeholder="Confirma tu nueva contraseþa" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100" id="btnChangePassword">
                            <i class="fas fa-lock"></i> Cambiar Contraseþa
                        </button>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <h6><i class="fas fa-shield-alt"></i> Consejos de Seguridad:</h6>
                <ul class="mb-0">
                    <li>Usa contraseþas ºnicas y seguras</li>
                    <li>No compartas tu contraseþa con nadie</li>
                    <li>Cambia tu contraseþa periµdicamente</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));
            const passwordForm = document.getElementById('changePasswordForm');
            const passwordSubmitButton = document.getElementById('btnChangePassword');
            const profileForm = document.getElementById('updateProfileForm');
            const profileSubmitButton = document.getElementById('btnUpdateProfile');

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df'
                });
            }

            if (profileForm && profileSubmitButton) {
                profileForm.addEventListener('submit', function () {
                    profileSubmitButton.disabled = true;
                    profileSubmitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';
                });
            }

            if (!passwordForm || !passwordSubmitButton) {
                return;
            }

            passwordForm.addEventListener('submit', function(e) {
                const newPass = document.getElementById('newPassword').value;
                const confirmPass = document.getElementById('confirmPassword').value;

                if (newPass !== confirmPass) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Contraseþas no coinciden',
                        text: 'Verifica que la nueva contraseþa y su confirmaciµn sean iguales.',
                        confirmButtonColor: '#4e73df'
                    });
                    return;
                }

                passwordSubmitButton.disabled = true;
                passwordSubmitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Actualizando...';
            });
        })();
    </script>
}
