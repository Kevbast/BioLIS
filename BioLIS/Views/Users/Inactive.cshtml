@model List<BioLIS.Models.User>

<link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Usuarios desactivados";
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container-fluid mt-4 users-page">
    <div class="users-header">
        <h2>
            <i class="fas fa-user-clock"></i> Usuarios desactivados
            <span class="badge bg-secondary">@(Model?.Count ?? 0)</span>
        </h2>
        <div class="users-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Volver a usuarios activos
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-4">
            <i class="fas fa-info-circle"></i> No hay usuarios desactivados.
        </div>
    }
    else
    {
        <div class="card users-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle users-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Usuario</th>
                                <th>Email</th>
                                <th>Rol</th>
                                <th>Médico Vinculado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><strong>@user.UserID</strong></td>
                                    <td>@user.Username</td>
                                    <td>@(string.IsNullOrWhiteSpace(user.Email) ? "Sin email" : user.Email)</td>
                                    <td>
                                        @if (user.RoleID == 1)
                                        {
                                            <span class="badge bg-danger">Admin</span>
                                        }
                                        else if (user.RoleID == 3)
                                        {
                                            <span class="badge bg-primary">Doctor</span>
                                        }
                                        else if (user.RoleID == 2)
                                        {
                                            <span class="badge bg-success">Laboratorio</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">ID: @user.RoleID</span>
                                        }
                                    </td>
                                    <td>@(user.Doctor?.FullName ?? "N/A")</td>
                                    <td class="text-center">
                                        <form asp-action="Reactivate" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.UserID" />
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="fas fa-rotate-left"></i> Reactivar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df'
                });
            }
        })();
    </script>
}