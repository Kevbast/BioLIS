@using System.Security.Claims
@model IEnumerable<BioLIS.Models.Patient>

<link rel="stylesheet" href="~/css/patients.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Gestión de Pacientes";
    var role = User.FindFirstValue(ClaimTypes.Role);
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 patients-page">
    <div class="patients-header">
        <h2>
            <i class="fas fa-users text-info"></i> Gestión de Pacientes
        </h2>
        <div class="d-flex gap-2">
            @if (role == "Admin")
            {
                <a asp-action="Inactive" class="btn btn-outline-secondary">
                    <i class="fas fa-user-clock"></i> Pacientes desactivados
                </a>
            }
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-user-plus"></i> Registrar Paciente
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center patients-empty py-4">
            <i class="fas fa-info-circle"></i> No hay pacientes registrados.
            <a asp-action="Create" class="alert-link">Registrar el primero</a>
        </div>
    }
    else
    {
        <div class="card patient-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover patient-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Foto</th>
                                <th>Nombre</th>
                                <th>Apellido</th>
                                <th>Género</th>
                                <th>Edad</th>
                                <th>Email</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model)
                            {
                                var age = DateTime.Now.Year - patient.BirthDate.Year;
                                if (DateTime.Now < patient.BirthDate.AddYears(age)) age--;

                                <tr>
                                    <td>@patient.PatientID</td>
                                    <td>
                                        <img src="~/images/pacientes/@patient.PhotoFilename"
                                             alt="@patient.FirstName"
                                             class="patient-avatar"
                                             onerror="this.src='/images/pacientes/default.png'" />
                                    </td>
                                    <td><strong>@patient.FirstName</strong></td>
                                    <td><strong>@patient.LastName</strong></td>
                                    <td>
                                        @if (patient.Gender == "M")
                                        {
                                            <span class="badge bg-primary"><i class="fas fa-mars"></i> Masculino</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="fas fa-venus"></i> Femenino</span>
                                        }
                                    </td>
                                    <td>@age años</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(patient.Email))
                                        {
                                            <i class="fas fa-envelope text-secondary"></i> @patient.Email
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin email</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group patient-table-actions" role="group">
                                            <a asp-action="Update" asp-route-patientId="@patient.PatientID"
                                               class="btn btn-sm btn-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            @if (role == "Admin")
                                            {
                                                <a asp-action="Delete" asp-route-patientId="@patient.PatientID"
                                                   class="btn btn-sm btn-danger js-delete-patient"
                                                   data-patient-name="@($"{patient.FirstName} {patient.LastName}")"
                                                   title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                            <a asp-action="History" asp-route-patientId="@patient.PatientID"
                                               class="btn btn-sm btn-info text-white" title="Ver Historial Predictivo">
                                                <i class="fas fa-chart-line"></i> Historial
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                Total de pacientes: <strong>@Model.Count()</strong>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-patient').forEach(function (button) {
                button.addEventListener('click', function (event) {
                    event.preventDefault();

                    const deleteUrl = button.getAttribute('href');
                    const patientName = button.dataset.patientName || 'este paciente';

                    Swal.fire({
                        icon: 'warning',
                        title: '¿Eliminar paciente?',
                        text: `Esta acción eliminará a ${patientName}.`,
                        showCancelButton: true,
                        confirmButtonText: 'Sí, eliminar',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#e74a3b',
                        cancelButtonColor: '#6c757d'
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            window.location.href = deleteUrl;
                        }
                    });
                });
            });
        })();
    </script>
}

