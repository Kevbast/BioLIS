<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BioLIS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BioLIS.styles.css" asp-append-version="true" />
    <!-- FontAwesome para iconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BioLIS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Dashboard
                            </a>
                        </li>

                        @* Pacientes: Admin y Laboratorio pueden ver *@
                        @{
                            var role = Context.Session.GetString("Role");
                        }

                        @if (role == "Admin" || role == "Laboratorio")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Patients" asp-action="Index">
                                    <i class="fas fa-users"></i> Pacientes
                                </a>
                            </li>
                        }

                        @* Médicos: Todos pueden ver (Admin gestiona, otros consultan) *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Doctors" asp-action="Index">
                                <i class="fas fa-user-md"></i> Médicos
                            </a>
                        </li>

                        @* Órdenes: Todos pueden ver (con diferentes permisos internos) *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Orders" asp-action="Index">
                                <i class="fas fa-file-medical"></i> Órdenes
                            </a>
                        </li>

                        @* Gestión Avanzada: Solo Admin *@
                        @if (role == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-cog"></i> Administración
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="Index">
                                            <i class="fas fa-users-cog"></i> Gestión de Usuarios
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="LabTests" asp-action="Index">
                                            <i class="fas fa-flask"></i> Catálogo de Exámenes
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="SampleTypes" asp-action="Index">
                                            <i class="fas fa-vial"></i> Tipos de Muestra
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="ReferenceRanges" asp-action="Index">
                                            <i class="fas fa-chart-line"></i> Rangos de Referencia
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Privacy">
                                            <i class="fas fa-shield-alt"></i> Políticas
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                    
                    @* Información del usuario logueado *@
                    @if (Context.Session.GetInt32("UserID").HasValue)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="userDropdown" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="~/images/users/@(Context.Session.GetString("Photo") ?? "default-user.png")" 
                                         alt="User" 
                                         style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover; margin-right: 8px;" 
                                         onerror="this.src='/images/users/default-user.png'" />
                                    <strong>@Context.Session.GetString("Username")</strong>
                                    <span class="badge bg-primary ms-1">@Context.Session.GetString("Role")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item disabled">
                                            <small class="text-muted">ID: @Context.Session.GetInt32("UserID")</small>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="ChangePassword">
                                            🔑 Cambiar Contraseña
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Auth" asp-action="Logout">
                                            🚪 Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BioLIS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
