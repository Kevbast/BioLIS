@using System.Security.Claims
@model BioLab.Models.Order

<link rel="stylesheet" href="~/css/orders.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Detalles de la Orden";
    var results = ViewData["Results"] as List<BioLab.Models.TestResult> ?? new List<BioLab.Models.TestResult>();
    var role = User.FindFirstValue(ClaimTypes.Role);
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 orders-page">
    <div class="orders-header animate-fade-up">
        <h2>
            <i class="fas fa-file-medical text-primary"></i>
            <span class="order-header-title">Orden: <strong>@Model.OrderNumber</strong></span>
        </h2>
        <div>
            <a asp-action="Index" class="btn btn-secondary hover-pulse">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
            @if (role == "Admin")
            {
                <a asp-action="Delete" asp-route-orderId="@Model.OrderID" class="btn btn-danger hover-pulse">
                    <i class="fas fa-trash"></i> Eliminar
                </a>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3 animate-fade-up delay-100">
            <div class="card h-100 order-details-card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0 order-section-title"><i class="fas fa-user"></i> Informaci¾n del Paciente</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <img src="~/images/pacientes/@Model.Patient.PhotoFilename"
                                 alt="@Model.Patient.FirstName"
                                 class="rounded-circle border border-3 border-info"
                                 style="width: 100px; height: 100px; object-fit: cover;"
                                 onerror="this.src='/images/pacientes/default.png'" />
                        </div>
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">ID:</dt>
                                <dd class="col-sm-7">@Model.Patient.PatientID</dd>

                                <dt class="col-sm-5">Nombre:</dt>
                                <dd class="col-sm-7"><strong>@Model.Patient.FirstName @Model.Patient.LastName</strong></dd>

                                <dt class="col-sm-5">Gķnero:</dt>
                                <dd class="col-sm-7">
                                    @if (Model.Patient.Gender == "M")
                                    {
                                        <span class="badge bg-primary"><i class="fas fa-mars"></i> Masculino</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-venus"></i> Femenino</span>
                                    }
                                </dd>

                                <dt class="col-sm-5">Fecha Nac.:</dt>
                                <dd class="col-sm-7">@Model.Patient.BirthDate.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-5">Email:</dt>
                                <dd class="col-sm-7">
                                    @if (!string.IsNullOrEmpty(Model.Patient.Email))
                                    {
                                        <span>@Model.Patient.Email</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No disponible</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3 animate-fade-up delay-200">
            <div class="card h-100 order-details-card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 order-section-title"><i class="fas fa-user-md"></i> Mķdico Solicitante</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">ID:</dt>
                        <dd class="col-sm-7">@Model.Doctor.DoctorID</dd>

                        <dt class="col-sm-5">Nombre:</dt>
                        <dd class="col-sm-7"><strong>@Model.Doctor.FullName</strong></dd>

                        <dt class="col-sm-5">Licencia:</dt>
                        <dd class="col-sm-7">
                            @if (!string.IsNullOrEmpty(Model.Doctor.LicenseNumber))
                            {
                                <span class="badge bg-info">@Model.Doctor.LicenseNumber</span>
                            }
                            else
                            {
                                <span class="text-muted">Sin licencia</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Email:</dt>
                        <dd class="col-sm-7">
                            @if (!string.IsNullOrEmpty(Model.Doctor.Email))
                            {
                                <span>@Model.Doctor.Email</span>
                            }
                            else
                            {
                                <span class="text-muted">No disponible</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Fecha Orden:</dt>
                        <dd class="col-sm-7">
                            <i class="fas fa-calendar"></i> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card order-details-card mt-3 animate-fade-up delay-300">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0 order-section-title">
                <i class="fas fa-flask"></i> Exßmenes Solicitados
                <span class="badge bg-light text-dark">@results.Count</span>
            </h5>
        </div>
        <div class="card-body">
            @if (!results.Any())
            {
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle"></i> No hay exßmenes asociados a esta orden.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover order-results-table">
                        <thead class="table-light">
                            <tr>
                                <th>Examen</th>
                                <th>Tipo de Muestra</th>
                                <th>Unidades</th>
                                <th>Resultado</th>
                                <th>Estado</th>
                                <th>Observaciones</th>
                                <th>AuditorĒa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in results)
                            {
                                <tr>
                                    <td>
                                        <strong>@result.LabTest.TestName</strong>
                                    </td>
                                    <td>
                                        <span class="badge" style="background-color: @GetColorBadge(result.LabTest.SampleType.ContainerColor); color: #fff; border: 1px solid rgba(0,0,0,0.1);">
                                            <i class="fas fa-vial"></i> @result.LabTest.SampleType.SampleName
                                        </span>
                                    </td>
                                    <td>@result.LabTest.Units</td>
                                    <td>
                                        @if (result.ResultValue.HasValue)
                                        {
                                            <strong>@result.ResultValue.Value</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Pendiente</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!result.ResultValue.HasValue)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-clock"></i> Pendiente
                                            </span>
                                        }
                                        else if (!string.IsNullOrEmpty(result.AlertLevel))
                                        {
                                            <span class="@BioLab.Models.AlertLevels.GetBadgeClass(result.AlertLevel)">
                                                <i class="fas @GetIconForAlertLevel(result.AlertLevel)"></i>
                                                @BioLab.Models.AlertLevels.GetDisplayName(result.AlertLevel)
                                            </span>
                                        }
                                        else if (result.IsAbnormal)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-triangle"></i> Anormal
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Normal
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(result.Notes))
                                        {
                                            <span>@result.Notes</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted d-block">
                                            Ingreso:
                                            @if (result.EnteredByUser != null)
                                            {
                                                <span>@result.EnteredByUser.DisplayName</span>
                                            }
                                            else
                                            {
                                                <span>N/D</span>
                                            }
                                        </small>
                                        <small class="text-muted d-block">
                                            Fecha: @result.EnteredDate.ToString("dd/MM/yyyy HH:mm")
                                        </small>

                                        @if (result.ModifiedByUser != null || result.ModifiedDate.HasValue)
                                        {
                                            <small class="text-muted d-block mt-1">
                                                Modif:
                                                @if (result.ModifiedByUser != null)
                                                {
                                                    <span>@result.ModifiedByUser.DisplayName</span>
                                                }
                                                else
                                                {
                                                    <span>N/D</span>
                                                }
                                            </small>
                                            <small class="text-muted d-block">
                                                Fecha: @(result.ModifiedDate?.ToString("dd/MM/yyyy HH:mm") ?? "N/D")
                                            </small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card order-details-card mt-3 mb-5 animate-fade-up delay-400">
        <div class="card-header bg-secondary text-white">
            <h6 class="mb-0 order-section-title"><i class="fas fa-info-circle"></i> Informaci¾n Adicional y Acciones</h6>
        </div>
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="mb-3 mb-md-0">
                <p class="mb-1"><i class="fas fa-barcode"></i> <strong>C¾digo de Barras:</strong> @Model.OrderNumber</p>
                <p class="mb-1"><i class="fas fa-calendar-alt"></i> <strong>Fecha de Creaci¾n:</strong> @Model.OrderDate.ToString("dddd, dd MMMM yyyy HH:mm:ss")</p>
                <p class="mb-0">
                    <i class="fas fa-flag"></i> <strong>Estado Actual:</strong>
                    <span class="badge @(Model.Status == "Aprobada" ? "bg-success" : Model.Status == "Completada" ? "bg-info text-dark" : Model.Status == "EnProceso" ? "bg-warning text-dark" : "bg-secondary") fs-6">
                        @Model.Status
                    </span>
                </p>
                @if (Model.Status == "Aprobada")
                {
                    <p class="mb-0 mt-2">
                        <i class="fas fa-user-check"></i> <strong>Aprobada por:</strong>
                        @if (Model.ApprovedByUser != null)
                        {
                            <span>@Model.ApprovedByUser.DisplayName</span>
                        }
                        else
                        {
                            <span class="text-muted">No disponible</span>
                        }
                    </p>
                }

                @if (Model.CompletedDate.HasValue)
                {
                    <p class="mb-0 mt-2">
                        <i class="fas fa-calendar-check"></i> <strong>Fecha de cierre laboratorio:</strong>
                        <span>@Model.CompletedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                    </p>
                }
            </div>

            <div class="order-actions">
                @if ((role == "Admin" || role == "Laboratorio") && Model.Status != "Aprobada")
                {
                    <a asp-action="EnterResults" asp-route-orderId="@Model.OrderID" class="btn btn-primary hover-pulse">
                        <i class="fas fa-edit"></i> Ingresar Resultados
                    </a>
                }

                @if ((role == "Admin" || role == "Laboratorio") && Model.Status == "EnProceso")
                {
                    <form asp-action="ChangeStatus" asp-controller="Orders" method="post">
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <input type="hidden" name="status" value="Completada" />
                        <button type="submit" class="btn btn-info text-white hover-pulse" title="Indica que el laboratorio finaliz¾ los anßlisis">
                            <i class="fas fa-check-double"></i> Marcar Completada
                        </button>
                    </form>
                }

                @if (role == "Doctor" && Model.Status == "Completada")
                {
                    <form asp-action="ChangeStatus" asp-controller="Orders" method="post">
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <input type="hidden" name="status" value="Aprobada" />
                        <button type="submit" class="btn btn-success hover-pulse" title="El mķdico valida y cierra los resultados">
                            <i class="fas fa-user-check"></i> Aprobar Orden
                        </button>
                    </form>
                }
                else if (role == "Admin" && Model.Status == "Completada")
                {
                    <button class="btn btn-outline-secondary" disabled title="Solo el mķdico solicitante puede aprobar la orden">
                        <i class="fas fa-user-check"></i> Aprobaci¾n solo por Mķdico
                    </button>
                }

                @if (Model.Status == "Aprobada")
                {
                    <a asp-action="Print" asp-route-orderId="@Model.OrderID" target="_blank" class="btn btn-dark hover-pulse">
                        <i class="fas fa-print"></i> Imprimir Orden
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary" disabled title="La orden debe estar en estado 'Aprobada' para imprimirse">
                        <i class="fas fa-print"></i> Imprimir (Bloqueado)
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }
        })();
    </script>
}

@functions {
    string GetColorBadge(string containerColor)
    {
        return containerColor?.ToLower() switch
        {
            "rojo" => "#dc3545",
            "lila" or "morado" => "#6f42c1",
            "amarillo" => "#ffc107",
            "verde" => "#28a745",
            "azul" => "#0d6efd",
            "celeste" => "#0dcaf0",
            "gris" => "#6c757d",
            "negro" => "#212529",
            "blanco" => "#9ca3af", // Un gris mßs oscuro para texto visible en fondo claro
            "transparente" => "#adb5bd",
            _ => "#17a2b8"
        };
    }

    string GetIconForAlertLevel(string? alertLevel)
    {
        return alertLevel switch
        {
            "NORMAL" => "fa-check",
            "ANORMAL" => "fa-exclamation-triangle",
            "CRITICO" => "fa-skull-crossbones",
            "SIN_RANGO" => "fa-question-circle",
            _ => "fa-info-circle"
        };
    }
}