@using System.Security.Claims
@model List<BioLab.Models.Order>

<link rel="stylesheet" href="~/css/orders.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Gestión de Órdenes";
    var role = User.FindFirstValue(ClaimTypes.Role);
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 orders-page">
    <div class="orders-header">
        <h2>
            <i class="fas fa-file-medical text-success"></i> 
            @if (role == "Doctor")
            {
                <text>Mis Órdenes de Laboratorio</text>
            }
            else
            {
                <text>Gestión de Órdenes</text>
            }
        </h2>
        @if (role == "Admin" || role == "Laboratorio" || role == "Doctor")
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Nueva Orden
            </a>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center order-empty py-4">
            <i class="fas fa-info-circle"></i> 
            @if (role == "Doctor")
            {
                <text>No tienes órdenes registradas.</text>
            }
            else
            {
                <text>No hay órdenes registradas. <a asp-action="Create" class="alert-link">Crear la primera</a></text>
            }
        </div>
    }
    else
    {
        <div class="card order-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover orders-table">
                        <thead>
                            <tr>
                                <th>Número de Orden</th>
                                <th>Fecha</th>
                                <th>Paciente</th>
                                <th>Doctor</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary">
                                            <i class="fas fa-barcode"></i> @order.OrderNumber
                                        </strong>
                                    </td>
                                    <td>
                                        <i class="fas fa-calendar"></i> 
                                        @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td>
                                        <i class="fas fa-user"></i> 
                                        @order.Patient.FirstName @order.Patient.LastName
                                    </td>
                                    <td>
                                        <i class="fas fa-user-md text-primary"></i> 
                                        @order.Doctor.FullName
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = "bg-secondary";
                                            string iconClass = "fa-clock";

                                            switch (order.Status)
                                            {
                                                case "Aprobada":
                                                    badgeClass = "bg-success";
                                                    iconClass = "fa-check-circle";
                                                    break;
                                                case "Completada":
                                                    badgeClass = "bg-info text-dark";
                                                    iconClass = "fa-check-double";
                                                    break;
                                                case "EnProceso":
                                                    badgeClass = "bg-warning text-dark";
                                                    iconClass = "fa-spinner fa-spin"; // Ańade un pequeńo giro si quieres
                                                    break;
                                                case "Pendiente":
                                                default:
                                                    badgeClass = "bg-secondary";
                                                    iconClass = "fa-clock";
                                                    break;
                                            }
                                        }
                                        <span class="badge @badgeClass fs-6">
                                            <i class="fas @iconClass"></i> @order.Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                            <div class="btn-group order-table-actions" role="group">
                                            <a asp-action="Details" asp-route-orderId="@order.OrderID"
                                               class="btn btn-sm btn-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (role == "Admin")
                                            {
                                                <a asp-action="Delete" asp-route-orderId="@order.OrderID"
                                                   class="btn btn-sm btn-danger js-delete-order"
                                                   data-order-number="@order.OrderNumber"
                                                   title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                <div class="row">
                    <div class="col-md-6">
                        <i class="fas fa-file-medical"></i> 
                        Total de órdenes: <strong>@Model.Count</strong>
                    </div>
                    <div class="col-md-6 text-end">
                        <i class="fas fa-calendar-day"></i> 
                        Hoy: <strong>@Model.Count(o => o.OrderDate.Date == DateTime.Today)</strong>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-order').forEach(function (button) {
                button.addEventListener('click', async function (event) {
                    event.preventDefault();

                    const deletePageUrl = button.getAttribute('href');
                    const orderNumber = button.dataset.orderNumber || 'esta orden';

                    try {
                        const response = await fetch(deletePageUrl, {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('No se pudo cargar la confirmación de eliminación.');
                        }

                        const html = await response.text();
                        const parser = new DOMParser();
                        const documentFromResponse = parser.parseFromString(html, 'text/html');
                        const deleteForm = documentFromResponse.querySelector('form[action*="/Orders/Delete"]');

                        if (!deleteForm) {
                            throw new Error('No se encontró el formulario de confirmación.');
                        }

                        const antiForgery = deleteForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                        const orderId = deleteForm.querySelector('input[name="OrderID"], input[name="orderId"]')?.value || '';
                        const formAction = deleteForm.getAttribute('action') || '/Orders/Delete';

                        const summaryContent = documentFromResponse.querySelector('.delete-order-summary')?.outerHTML
                            || `<div class="text-start"><p class="mb-2"><strong>Orden:</strong> ${orderNumber}</p><p class="mb-0 text-muted">Esta acción no se puede deshacer.</p></div>`;

                        const result = await Swal.fire({
                            icon: 'warning',
                            title: 'Confirmar eliminación',
                            html: summaryContent,
                            showCancelButton: true,
                            confirmButtonText: 'Sí, eliminar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#e74a3b',
                            cancelButtonColor: '#6c757d'
                        });

                        if (!result.isConfirmed) {
                            return;
                        }

                        const postForm = document.createElement('form');
                        postForm.method = 'post';
                        postForm.action = formAction;

                        if (antiForgery) {
                            const tokenInput = document.createElement('input');
                            tokenInput.type = 'hidden';
                            tokenInput.name = '__RequestVerificationToken';
                            tokenInput.value = antiForgery;
                            postForm.appendChild(tokenInput);
                        }

                        const idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'orderId';
                        idInput.value = orderId;
                        postForm.appendChild(idInput);

                        document.body.appendChild(postForm);
                        postForm.submit();
                    } catch (error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: error.message || 'Ocurrió un error al preparar la eliminación.',
                            confirmButtonColor: '#4e73df'
                        });
                    }
                });
            });
        })();
    </script>
}
