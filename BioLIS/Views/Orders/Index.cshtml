@using System.Security.Claims
@model List<BioLab.Models.Order>

@{
    ViewData["Title"] = "Gestión de Órdenes";
    var role = User.FindFirstValue(ClaimTypes.Role);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-file-medical text-success"></i> 
            @if (role == "Doctor")
            {
                <text>Mis Órdenes de Laboratorio</text>
            }
            else
            {
                <text>Gestión de Órdenes</text>
            }
        </h2>
        @if (role == "Admin" || role == "Laboratorio")
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Nueva Orden
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> 
            @if (role == "Doctor")
            {
                <text>No tienes órdenes registradas.</text>
            }
            else
            {
                <text>No hay órdenes registradas. <a asp-action="Create" class="alert-link">Crear la primera</a></text>
            }
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Número de Orden</th>
                                <th>Fecha</th>
                                <th>Paciente</th>
                                <th>Doctor</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary">
                                            <i class="fas fa-barcode"></i> @order.OrderNumber
                                        </strong>
                                    </td>
                                    <td>
                                        <i class="fas fa-calendar"></i> 
                                        @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td>
                                        <i class="fas fa-user"></i> 
                                        @order.Patient.FirstName @order.Patient.LastName
                                    </td>
                                    <td>
                                        <i class="fas fa-user-md text-primary"></i> 
                                        @order.Doctor.FullName
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = "bg-secondary";
                                            string iconClass = "fa-clock";

                                            switch (order.Status)
                                            {
                                                case "Aprobada":
                                                    badgeClass = "bg-success";
                                                    iconClass = "fa-check-circle";
                                                    break;
                                                case "Completada":
                                                    badgeClass = "bg-info text-dark";
                                                    iconClass = "fa-check-double";
                                                    break;
                                                case "EnProceso":
                                                    badgeClass = "bg-warning text-dark";
                                                    iconClass = "fa-spinner fa-spin"; // Ańade un pequeńo giro si quieres
                                                    break;
                                                case "Pendiente":
                                                default:
                                                    badgeClass = "bg-secondary";
                                                    iconClass = "fa-clock";
                                                    break;
                                            }
                                        }
                                        <span class="badge @badgeClass fs-6">
                                            <i class="fas @iconClass"></i> @order.Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-orderId="@order.OrderID"
                                               class="btn btn-sm btn-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (role == "Admin")
                                            {
                                                <a asp-action="Delete" asp-route-orderId="@order.OrderID"
                                                   class="btn btn-sm btn-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                <div class="row">
                    <div class="col-md-6">
                        <i class="fas fa-file-medical"></i> 
                        Total de órdenes: <strong>@Model.Count</strong>
                    </div>
                    <div class="col-md-6 text-end">
                        <i class="fas fa-calendar-day"></i> 
                        Hoy: <strong>@Model.Count(o => o.OrderDate.Date == DateTime.Today)</strong>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-ocultar alertas después de 5 segundos
        setTimeout(function () {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
