@model BioLIS.Models.Order

@{
    ViewData["Title"] = "Eliminar Orden";
}

<link rel="stylesheet" href="~/css/orders.css" asp-append-version="true" />

<div class="container mt-4 orders-page">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-danger order-details-card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Confirmar Eliminación de Orden
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger delete-order-summary">
                        <i class="fas fa-skull-crossbones"></i>
                        <strong>ˇADVERTENCIA!</strong> 
                        Esta acción eliminará permanentemente:
                        <ul class="mb-0 mt-2">
                            <li>La orden <strong>@Model.OrderNumber</strong></li>
                            <li>Todos los <strong>@Model.TestResults.Count resultado(s)</strong> asociados</li>
                        </ul>
                        <p class="mb-0 mt-2 text-danger"><strong>Esta acción no se puede deshacer.</strong></p>
                    </div>

                    <h5 class="mb-3"><i class="fas fa-file-medical"></i> Datos de la Orden</h5>

                    <dl class="row">
                        <dt class="col-sm-4"><i class="fas fa-hashtag"></i> ID:</dt>
                        <dd class="col-sm-8">@Model.OrderID</dd>

                        <dt class="col-sm-4"><i class="fas fa-barcode"></i> Número de Orden:</dt>
                        <dd class="col-sm-8"><strong class="text-primary">@Model.OrderNumber</strong></dd>

                        <dt class="col-sm-4"><i class="fas fa-calendar"></i> Fecha:</dt>
                        <dd class="col-sm-8">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4"><i class="fas fa-user"></i> Paciente:</dt>
                        <dd class="col-sm-8">@Model.Patient.FirstName @Model.Patient.LastName (ID: @Model.PatientID)</dd>

                        <dt class="col-sm-4"><i class="fas fa-user-md"></i> Doctor:</dt>
                        <dd class="col-sm-8">@Model.Doctor.FullName (ID: @Model.DoctorID)</dd>

                        <dt class="col-sm-4"><i class="fas fa-flask"></i> Exámenes:</dt>
                        <dd class="col-sm-8">@Model.TestResults.Count exámenes asociados</dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="OrderID" />
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Sí, Eliminar Orden
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <i class="fas fa-info-circle"></i> 
                <strong>Nota:</strong> 
                Solo los administradores pueden eliminar órdenes. Esta acción eliminará también todos los resultados asociados.
            </div>
        </div>
    </div>
</div>
