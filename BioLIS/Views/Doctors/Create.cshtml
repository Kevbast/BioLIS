@model BioLIS.Models.Doctor

@{
    ViewData["Title"] = "Registrar MÈdico";
}

<link rel="stylesheet" href="~/css/doctors.css" asp-append-version="true" />

<div class="container mt-4 doctors-page">
    <div class="doctors-header">
        <h2><i class="fas fa-user-md text-success"></i> Registrar Nuevo MÈdico</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card doctor-form-card">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-success">
                        Datos del mÈdico
                    </h6>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" id="doctorCreateForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Nombre Completo -->
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">
                                <i class="fas fa-user"></i> Nombre Completo *
                            </label>
                            <input asp-for="FullName" class="form-control" placeholder="Ej: Dr. Juan PÈrez Gonz·lez" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <!-- N˙mero de Licencia -->
                        <div class="mb-3">
                            <label asp-for="LicenseNumber" class="form-label">
                                <i class="fas fa-id-card"></i> N˙mero de Licencia MÈdica
                            </label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="Ej: MED-12345" />
                            <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                            <small class="form-text text-muted">Opcional. Ej: MED-001, CMP-54321</small>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope"></i> Email
                            </label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="doctor@hospital.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                            <small class="form-text text-muted">Opcional. Para notificaciones y contacto.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">
                                <i class="fas fa-phone"></i> TelÈfono
                            </label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Ej: +34 600 123 456" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <!-- Botones -->
                        <div class="doctor-form-actions mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-success doctors-submit" id="btnCreateDoctor">
                                <i class="fas fa-save"></i> Guardar MÈdico
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- InformaciÛn adicional -->
            <div class="alert alert-info mt-3 doctor-note">
                <i class="fas fa-info-circle"></i> 
                <strong>Nota:</strong> 
                Este mÈdico podr· solicitar Ûrdenes de laboratorio. 
                Si desea que tenga acceso al sistema, debe crear un usuario vinculado en 
                <a asp-controller="Users" asp-action="Create" class="alert-link">GestiÛn de Usuarios</a>.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const form = document.getElementById('doctorCreateForm');
            const submitButton = document.getElementById('btnCreateDoctor');

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function () {
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';
            });
        })();
    </script>
}
