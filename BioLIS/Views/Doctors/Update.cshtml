@model BioLIS.Models.Doctor

@{
    ViewData["Title"] = "Editar Mťdico";
}

<link rel="stylesheet" href="~/css/doctors.css" asp-append-version="true" />

<div class="container mt-4 doctors-page">
    <div class="doctors-header">
        <h2><i class="fas fa-user-edit text-warning"></i> Editar Mťdico</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card doctor-form-card">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-warning">
                        Editar informaciůn del mťdico
                    </h6>
                </div>
                <div class="card-body">
                    <form asp-action="Update" method="post" id="doctorUpdateForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- ID Oculto -->
                        <input asp-for="DoctorID" type="hidden" />

                        <!-- Informaciůn del ID (Solo lectura) -->
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-hashtag"></i> ID del Mťdico
                            </label>
                            <input type="text" class="form-control-plaintext" readonly value="@Model.DoctorID" />
                        </div>

                        <!-- Nombre Completo -->
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">
                                <i class="fas fa-user"></i> Nombre Completo *
                            </label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <!-- Nķmero de Licencia -->
                        <div class="mb-3">
                            <label asp-for="LicenseNumber" class="form-label">
                                <i class="fas fa-id-card"></i> Nķmero de Licencia Mťdica
                            </label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="Ej: MED-12345" />
                            <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope"></i> Email
                            </label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">
                                <i class="fas fa-phone"></i> Telťfono
                            </label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <!-- Botones -->
                        <div class="doctor-form-actions mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning doctors-submit" id="btnUpdateDoctor">
                                <i class="fas fa-save"></i> Actualizar Informaciůn
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Informaciůn sobre usuarios vinculados -->
            <div class="alert alert-secondary mt-3 doctor-note">
                <i class="fas fa-link"></i> 
                <strong>Usuarios vinculados:</strong> 
                Si este mťdico tiene un usuario del sistema, los cambios aquŪ NO afectan su cuenta de acceso. 
                Para modificar credenciales, ve a 
                <a asp-controller="Users" asp-action="Index" class="alert-link">Gestiůn de Usuarios</a>.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const form = document.getElementById('doctorUpdateForm');
            const submitButton = document.getElementById('btnUpdateDoctor');

            if (!form || !submitButton) {
                return;
            }

            form.addEventListener('submit', function () {
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Actualizando...';
            });
        })();
    </script>
}
