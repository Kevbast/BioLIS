@using System.Security.Claims
@model List<BioLIS.Models.Doctor>

<link rel="stylesheet" href="~/css/doctors.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Gestión de Médicos";
    var role = User.FindFirstValue(ClaimTypes.Role);
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 doctors-page">
    <div class="doctors-header">
        <h2>
            <i class="fas fa-user-md text-primary"></i> 
            @if (role == "Admin")
            {
                <text>Gestión de Médicos</text>
            }
            else
            {
                <text>Directorio de Médicos</text>
            }
        </h2>
        @if (role == "Admin")
        {
            <div class="d-flex gap-2">
                <a asp-action="Inactive" class="btn btn-outline-secondary">
                    <i class="fas fa-user-clock"></i> Médicos desactivados
                </a>
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> Registrar Médico
                </a>
            </div>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center doctors-empty py-4">
            <i class="fas fa-info-circle"></i> No hay médicos registrados.
            <a asp-action="Create" class="alert-link">Registrar el primero</a>
        </div>
    }
    else
    {
        <div class="card doctor-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover doctor-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre Completo</th>
                                <th>Licencia Médica</th>
                                <th>Email</th>
                                @if (role == "Admin")
                                {
                                    <th class="text-center">Acciones</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doctor in Model)
                            {
                                <tr>
                                    <td>@doctor.DoctorID</td>
                                    <td>
                                        <i class="fas fa-stethoscope text-primary"></i>
                                        <strong>@doctor.FullName</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doctor.LicenseNumber))
                                        {
                                            <span class="badge bg-info">@doctor.LicenseNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin licencia</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doctor.Email))
                                        {
                                            <i class="fas fa-envelope text-secondary"></i> @doctor.Email
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin email</span>
                                        }
                                    </td>
                                    @if (role == "Admin")
                                    {
                                        <td class="text-center">
                                            <div class="btn-group doctor-table-actions" role="group">
                                                <a asp-action="Update" asp-route-doctorId="@doctor.DoctorID"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-doctorId="@doctor.DoctorID"
                                                   class="btn btn-sm btn-danger js-delete-doctor"
                                                   data-doctor-name="@doctor.FullName"
                                                   title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                Total de médicos: <strong>@Model.Count</strong>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df',
                    timer: 2600,
                    timerProgressBar: true
                });
            }

            document.querySelectorAll('.js-delete-doctor').forEach(function (button) {
                button.addEventListener('click', async function (event) {
                    event.preventDefault();

                    const deletePageUrl = button.getAttribute('href');
                    const doctorName = button.dataset.doctorName || 'este médico';

                    try {
                        const response = await fetch(deletePageUrl, {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('No se pudo cargar la confirmación de eliminación.');
                        }

                        const html = await response.text();
                        const parser = new DOMParser();
                        const documentFromResponse = parser.parseFromString(html, 'text/html');
                        const deleteForm = documentFromResponse.querySelector('form[action*="/Doctors/Delete"]');

                        if (!deleteForm) {
                            throw new Error('No se encontró el formulario de confirmación.');
                        }

                        const antiForgery = deleteForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                        const doctorId = deleteForm.querySelector('input[name="DoctorID"], input[name="doctorId"]')?.value || '';
                        const formAction = deleteForm.getAttribute('action') || '/Doctors/Delete';

                        const summaryContent = documentFromResponse.querySelector('.delete-doctor-summary')?.outerHTML
                            || `<div class="text-start"><p class="mb-2"><strong>Nombre:</strong> ${doctorName}</p><p class="mb-0 text-muted">Esta acción no se puede deshacer.</p></div>`;

                        const result = await Swal.fire({
                            icon: 'warning',
                            title: 'Confirmar eliminación',
                            html: summaryContent,
                            showCancelButton: true,
                            confirmButtonText: 'Sí, eliminar',
                            cancelButtonText: 'Cancelar',
                            confirmButtonColor: '#e74a3b',
                            cancelButtonColor: '#6c757d'
                        });

                        if (!result.isConfirmed) {
                            return;
                        }

                        const postForm = document.createElement('form');
                        postForm.method = 'post';
                        postForm.action = formAction;

                        if (antiForgery) {
                            const tokenInput = document.createElement('input');
                            tokenInput.type = 'hidden';
                            tokenInput.name = '__RequestVerificationToken';
                            tokenInput.value = antiForgery;
                            postForm.appendChild(tokenInput);
                        }

                        const idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'doctorId';
                        idInput.value = doctorId;
                        postForm.appendChild(idInput);

                        document.body.appendChild(postForm);
                        postForm.submit();
                    } catch (error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: error.message || 'Ocurrió un error al preparar la eliminación.',
                            confirmButtonColor: '#4e73df'
                        });
                    }
                });
            });
        })();
    </script>
}
