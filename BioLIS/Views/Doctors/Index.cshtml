@using System.Security.Claims
@model List<BioLab.Models.Doctor>

@{
    ViewData["Title"] = "Gestiůn de Mťdicos";
    var role = User.FindFirstValue(ClaimTypes.Role);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-user-md text-primary"></i> 
            @if (role == "Admin")
            {
                <text>Gestiůn de Mťdicos</text>
            }
            else
            {
                <text>Directorio de Mťdicos</text>
            }
        </h2>
        @if (role == "Admin")
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Registrar Mťdico
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> No hay mťdicos registrados.
            <a asp-action="Create" class="alert-link">Registrar el primero</a>
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Nombre Completo</th>
                                <th>Licencia Mťdica</th>
                                <th>Email</th>
                                @if (role == "Admin")
                                {
                                    <th class="text-center">Acciones</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doctor in Model)
                            {
                                <tr>
                                    <td>@doctor.DoctorID</td>
                                    <td>
                                        <i class="fas fa-stethoscope text-primary"></i>
                                        <strong>@doctor.FullName</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doctor.LicenseNumber))
                                        {
                                            <span class="badge bg-info">@doctor.LicenseNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin licencia</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doctor.Email))
                                        {
                                            <i class="fas fa-envelope text-secondary"></i> @doctor.Email
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin email</span>
                                        }
                                    </td>
                                    @if (role == "Admin")
                                    {
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Update" asp-route-doctorId="@doctor.DoctorID"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-doctorId="@doctor.DoctorID"
                                                   class="btn btn-sm btn-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                Total de mťdicos: <strong>@Model.Count</strong>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-ocultar alertas despuťs de 5 segundos
        setTimeout(function () {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}
