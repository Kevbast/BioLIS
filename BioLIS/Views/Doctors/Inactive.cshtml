@model List<BioLIS.Models.Doctor>

<link rel="stylesheet" href="~/css/doctors.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Médicos desactivados";
    var swalType = TempData["SwalType"]?.ToString();
    var swalTitle = TempData["SwalTitle"]?.ToString();
    var swalMessage = TempData["SwalMessage"]?.ToString();
}

<div class="container mt-4 doctors-page">
    <div class="doctors-header">
        <h2><i class="fas fa-user-clock text-secondary"></i> Médicos desactivados</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Volver a médicos activos
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-4">
            <i class="fas fa-info-circle"></i> No hay médicos desactivados.
        </div>
    }
    else
    {
        <div class="card doctor-list-card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover doctor-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Licencia</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doctor in Model)
                            {
                                <tr>
                                    <td>@doctor.DoctorID</td>
                                    <td><strong>@doctor.FullName</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(doctor.LicenseNumber) ? "Sin licencia" : doctor.LicenseNumber)</td>
                                    <td>@(string.IsNullOrWhiteSpace(doctor.Email) ? "Sin email" : doctor.Email)</td>
                                    <td>@(string.IsNullOrWhiteSpace(doctor.PhoneNumber) ? "Sin teléfono" : doctor.PhoneNumber)</td>
                                    <td class="text-center">
                                        <form asp-action="Reactivate" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="doctorId" value="@doctor.DoctorID" />
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="fas fa-rotate-left"></i> Reactivar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const swalType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalType));
            const swalTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalTitle));
            const swalMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(swalMessage));

            if (swalType && swalTitle && typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: swalType,
                    title: swalTitle,
                    text: swalMessage ?? '',
                    confirmButtonColor: '#4e73df'
                });
            }
        })();
    </script>
}